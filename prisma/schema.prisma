generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, unaccent]
}

model User {
  id                        String             @id @default(cuid())
  name                      String?
  email                     String             @unique
  password                  String?
  image                     String?
  isMasterUser              Boolean            @default(false)
  receivesAppointmentEmails Boolean            @default(false)
  receivesBlockedDateEmails Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  featureGrants             UserFeatureGrant[]
  appointments              Appointment[]      @relation("AppointmentOwner")
  auditLogs                 AuditLog[]          @relation("AuditActor")
}

/// Immutable administrative activity trail. Payloads intentionally exclude passwords and patient contact data.
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String
  category    String
  action      String
  status      String   @default("SUCCESS")
  entityType  String?
  entityId    String?
  summary     String
  changes     Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([actorEmail, createdAt])
  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([summary(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([createdAt, id])
}

model Feature {
  key         String             @id
  name        String
  description String
  category    String
  createdAt   DateTime           @default(now())
  grants      UserFeatureGrant[]
}

model UserFeatureGrant {
  id         String   @id @default(cuid())
  userId     String
  featureKey String
  createdAt  DateTime @default(now())
  createdBy  String?
  feature    Feature  @relation(fields: [featureKey], references: [key], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([featureKey])
}

model Appointment {
  id          String            @id @default(cuid())
  date        DateTime
  time        String
  durationMin Int               @default(30)
  service     String
  parentName  String
  childName   String
  childAge    String?
  phone       String
  email       String?
  notes       String?
  status      AppointmentStatus @default(NEW)
  deletedAt   DateTime?
  deletedBy   String?
  ownerId     String?
  owner       User?             @relation("AppointmentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([deletedAt])
  @@index([status])
}

model MedicalService {
  id               String    @id @default(cuid())
  name             String
  description      String?
  priceCents       Int
  currency         String    @default("RON")
  isPaused         Boolean   @default(false)
  discountEnabled  Boolean   @default(false)
  discountPercent  Int       @default(0)
  discountStartsAt DateTime?
  discountEndsAt   DateTime?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isPaused])
  @@index([sortOrder])
}

model ClinicScheduleSlot {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  startTime   String
  endTime     String
  durationMin Int      @default(30)
  isPaused    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dayOfWeek])
  @@index([isPaused])
  @@index([sortOrder])
}

model ClinicBlockedDate {
  id        String    @id @default(cuid())
  date      DateTime  @unique
  endDate   DateTime?
  startTime String?
  endTime   String?
  reason    String?
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([date])
  @@index([endDate])
}

enum AppointmentStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
}
