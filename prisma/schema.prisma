generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, unaccent]
}

model User {
  id             String              @id @default(cuid())
  name           String?
  email          String              @unique
  password       String?
  image          String?
  isMasterUser   Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  featureGrants  UserFeatureGrant[]
  appointments   Appointment[]       @relation("AppointmentOwner")
}

model Feature {
  key         String             @id
  name        String
  description String
  category    String
  createdAt   DateTime           @default(now())
  grants      UserFeatureGrant[]
}

model UserFeatureGrant {
  id         String   @id @default(cuid())
  userId     String
  featureKey String
  createdAt  DateTime @default(now())
  createdBy  String?
  feature    Feature  @relation(fields: [featureKey], references: [key], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
  @@index([featureKey])
}

model Appointment {
  id          String            @id @default(cuid())
  date        DateTime
  time        String
  durationMin Int               @default(30)
  service     String
  parentName  String
  childName   String
  phone       String
  email       String?
  notes       String?
  status      AppointmentStatus @default(NEW)
  ownerId     String?
  owner       User?             @relation("AppointmentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([date])
  @@index([status])
}

model MedicalService {
  id               String    @id @default(cuid())
  name             String
  description      String?
  priceCents       Int
  currency         String    @default("RON")
  isPaused         Boolean   @default(false)
  discountEnabled  Boolean   @default(false)
  discountPercent  Int       @default(0)
  discountStartsAt DateTime?
  discountEndsAt   DateTime?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isPaused])
  @@index([sortOrder])
}

enum AppointmentStatus {
  NEW
  CONFIRMED
  COMPLETED
  CANCELLED
}
